<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 7a: fdroid-flavor manifest overlay. Contributes only the
    AccessibilityService declaration; AGP merges this with src/main/'s
    manifest at build time. The play-flavor overlay is intentionally empty
    so this <service> never reaches Play APKs.

    android:exported="true" is REQUIRED for AccessibilityServices: the
    Android AccessibilityManagerService runs in `system_server` (a separate
    UID), and exported="false" would silently prevent the system from
    binding — the service would not appear in Settings → Accessibility at
    all. The actual security gate is the
    `android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"`
    declaration: only the system holds that permission, so only the system
    can perform the framework binding.

    No <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE">
    here — that's the service-side permission, not a caller-side one.

    No FOREGROUND_SERVICE / FOREGROUND_SERVICE_SPECIAL_USE here — those are
    Phase 8's concerns (always-on toggle), and per ARCHITECTURE.md they ship
    only in the fdroid manifest, never in main.

    SPDX-License-Identifier: GPL-3.0-only
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Phase 8: foreground service permissions for AlwaysOnService.
         POST_NOTIFICATIONS gates the persistent FGS chip + streaming-result
         notifications on Android 13+. RECEIVE_BOOT_COMPLETED is NOT here —
         already declared in src/main/AndroidManifest.xml since Phase 1
         (HeliBoard's legacy SystemBroadcastReceiver). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <service
            android:name="com.aikeyboard.app.a11y.ScreenReaderService"
            android:exported="true"
            android:label="@string/screen_reader_service_summary"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Phase 8: AlwaysOnService — runs whenever Always-On Read & Respond
             is toggled on. specialUse FGS type per Android 14+ requirement;
             the <property> subtype is required by Google Play policy AND by
             the runtime check. The string "screen_reader_companion" appears
             in `dumpsys activity services` output for human auditing. -->
        <service
            android:name="com.aikeyboard.app.a11y.AlwaysOnService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="screen_reader_companion" />
        </service>

        <!-- Phase 8: Quick Settings tile. The system binds via the
             BIND_QUICK_SETTINGS_TILE permission. -->
        <service
            android:name="com.aikeyboard.app.a11y.ReadRespondTileService"
            android:exported="true"
            android:icon="@drawable/ic_read_respond"
            android:label="@string/ai_always_on_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name="com.aikeyboard.app.a11y.ClipboardCopyReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aikeyboard.app.ACTION_CLIPBOARD_COPY" />
            </intent-filter>
        </receiver>

        <!-- Phase 8: BootReceiver re-starts AlwaysOnService after device boot
             when the user previously enabled always-on. exported="true" is
             required because the system's ActivityManager (different UID)
             sends BOOT_COMPLETED. directBootAware="false" defers invocation
             until after user unlock — sidesteps Tink's CE-only Keystore. -->
        <receiver
            android:name="com.aikeyboard.app.a11y.BootReceiver"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
