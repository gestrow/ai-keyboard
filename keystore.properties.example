# Phase 12 §8.3: keystore.properties template. Copy this file to
# `keystore.properties` (which is gitignored) at the repo root and fill in
# the real values. See BUILD.md for the keytool command that generates the
# keystore.
#
# All four properties are required. Paths are resolved relative to repo
# root; the convention is release-keys/aikeyboard-release.jks (also
# gitignored).
keystore.path=release-keys/aikeyboard-release.jks
keystore.password=CHANGE_ME
key.alias=aikeyboard-release
key.password=CHANGE_ME
